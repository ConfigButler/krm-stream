{
  "name": "krm-stream DevContainer",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2.5.9": {
      "userUid": "automatic",
      "userGid": "automatic",
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.10.0": {}
  },
  "runArgs": [
    "--group-add=docker",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "forwardPorts": [8081],
  "portsAttributes": {
    "8081": {
      "label": "krm-stream-gateway (examples)",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "go.useLanguageServer": true,
        "go.gopath": "/go",
        "go.testExplorer.enable": true,
        "gopls": { "build.directoryFilters": ["-node_modules"] },
        "typescript.tsdk": "packages/krm-stream/node_modules/typescript/lib",
        "files.exclude": { "**/node_modules": true }
      },
      "extensions": [
        "golang.go",
        "anthropic.claude-code",
        "redhat.vscode-yaml"
      ]
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh '${containerWorkspaceFolder}'",
  "postStartCommand": "bash .devcontainer/post-start.sh '${containerWorkspaceFolder}'",
  "remoteUser": "vscode",
  // Anything under /home/vscode that is NOT a named volume lives in the container's writable
  // layer and is DESTROYED on rebuild (which editing this file triggers). Pin the things whose
  // loss is confusing: the gh token, the kubeconfig, the Go caches — and Claude's login.
  //
  // TWO THINGS ABOUT CLAUDE, both learned the hard way:
  //   1. Its credentials live in ~/.claude.json — a FILE at the home root, NOT inside ~/.claude/ —
  //      so mounting ~/.claude alone does NOT persist a login. post-create.sh symlinks it into
  //      persisted-home, which is why that volume exists.
  //   2. A named volume whose path does not exist in the image is created ROOT-owned, so `vscode`
  //      cannot write to it at all. post-create.sh chowns /home/vscode for exactly this reason.
  //      Without it: `claude` cannot log in, `gh auth login` cannot store a token, and the symptom
  //      gives you no clue why.
  "mounts": [
    "source=krm-stream-gomodcache,target=/go/pkg/mod,type=volume",
    "source=krm-stream-gobuildcache,target=/home/vscode/.cache/go-build,type=volume",
    "source=krm-stream-dotkube,target=/home/vscode/.kube,type=volume",
    "source=krm-stream-ghconfig,target=/home/vscode/.config/gh,type=volume",
    "source=krm-stream-claudeconfig,target=/home/vscode/.claude,type=volume",
    "source=krm-stream-persisted-home,target=/home/vscode/persisted-home,type=volume"
  ],
  "containerEnv": {
    "HOST_PROJECT_PATH": "${localWorkspaceFolder}",
    "PROJECT_PATH": "/workspaces/${localWorkspaceFolderBasename}",
    "GIT_USER_NAME": "${localEnv:GIT_USER_NAME}",
    "GIT_USER_EMAIL": "${localEnv:GIT_USER_EMAIL}"
  }
}
